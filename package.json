{
  "name": "jcs2-mod",
  "private": true,
  "description": "Jet Car Stunts 2 community mod — PR bot gates + APK release automation",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "wait-for-bots": "node wait_for_bots.mjs",
    "pr:bot-feedback-check": "node scripts/pr-bot-feedback-check.mjs",
    "pr:gates:check": "node scripts/pr-gates-check.mjs",
    "pr:gate-exempt-policy:verify": "node scripts/verify-pr-gate-exempt-policy.mjs",
    "pr:gate-logic:verify": "node scripts/verify-pr-gate-logic.mjs",
    "github:bot-gates:operator": "node scripts/github-bot-gates-operator.mjs",
    "branch-protection:apply": "node scripts/apply-branch-protection.mjs",
    "repo-merge-settings:apply": "node scripts/apply-repo-merge-settings.mjs",
    "chief:scan": "node scripts/run-workflow.mjs chief-scan.mjs",
    "pr:bot-feedback-audit": "node scripts/run-workflow.mjs pr-bot-feedback-check.mjs --audit-merged --limit 20",
    "ship:closeout:strict": "node scripts/run-workflow.mjs ship-closeout-strict.mjs",
    "git:graph-hygiene": "git fetch origin --prune"
  }
}
