# ============================================================
#  Jet Car Stunts 2 (community mod) — repo ignore rules
#  Tracked: the editable decompiled source (smali, res,
#  manifest, native lib). Everything below is excluded
#  because it is secret, regenerable, or too large for git.
# ============================================================

# --- Secrets: NEVER commit the signing key (contains the private key) ---
# Keep jcs2.keystore backed up somewhere safe & offline instead.
*.keystore
*.jks
*.p12
*.pem
keystore.properties
key.properties

# --- Build outputs (regenerate with: apktool b -> zipalign -> apksigner) ---
*.apk
*.aab
*.idsig
*.apk.idsig

# --- apktool build intermediates ---
decompiled/build/
decompiled/dist/
native_bridge/target/
_apk_build_*/
_modmenu_build_*/
_ghidra_livery*/

# --- Large static game media (~227 MB, unchanged from the original APK).
#     Excluded to keep the repo small. They remain in your working copy,
#     so local `apktool b` still works. To rebuild from a FRESH clone,
#     copy decompiled/assets/ back in from the original APK first. ---
decompiled/assets/

# --- Downloaded tooling (apktool.jar, jadx; large & re-downloadable) ---
tools/

# --- jadx readable-Java output (regenerate from classes.dex; reference only) ---
jadx-out/

# --- Loose decompiled dex / verification scratch ---
*.dex
_verify*/
_manifest/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/
