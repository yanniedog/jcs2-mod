# Jet Car Stunts 2 community mod ignore rules
#
# Tracked files are the editable decompiled source, mod menu source,
# native bridge source/stubs, and small deterministic overlays.
# Ignored files are secrets, build products, local test harnesses, or
# regenerated tool output.

# Signing secrets
*.keystore
*.jks
*.p12
*.pem
keystore.properties
key.properties

# Android package outputs
*.apk
*.aab
*.idsig
*.apk.idsig

# Build and test intermediates
decompiled/build/
decompiled/dist/
native_bridge/target/
_apk_build/
_modmenu_build/
_modmenu_build_*/
_stock_debug/
_verify*/
_manifest/
_ghidra*/

# Large static game media copied from the original APK.
# Keep these locally for apktool rebuilds; restore from the stock APK in a fresh clone.
decompiled/assets/

# Downloaded/recreated tools and reference output
tools/
jadx-out/
*.dex

# OS/editor files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/
