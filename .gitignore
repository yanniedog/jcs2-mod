# Jet Car Stunts 2 community mod ignore rules
#
# Tracked files are the editable decompiled source, mod menu source,
# native bridge source/stubs, and small deterministic overlays.
# Ignored files are secrets, build products, local test harnesses, or
# regenerated tool output.

# Signing secrets
*.keystore
*.jks
*.p12
*.pem
keystore.properties
key.properties

# Committed stable self-signed signing key (intentional, not a secret).
# Every release is self-signed with this key so in-place updates keep working.
!jcs2.keystore

# Android package outputs
*.apk
*.aab
*.idsig
*.apk.idsig

# Build and test intermediates
decompiled/build/
decompiled/dist/
native_bridge/target/
_apk_build/
_modmenu_build/
_modmenu_build_*/
_stock_debug/
_verify*/
_manifest/
_ghidra*/

# Large static game media copied from the original APK.
# Keep these locally for apktool rebuilds; restore from the stock APK in a fresh clone.
decompiled/assets/

# Downloaded/recreated tools and reference output
tools/
jadx-out/
*.dex

# Local scratch: ad-hoc emulator screenshots, one-off disasm/probe scripts,
# debug log dumps, and bot-coordination temp dirs left in the repo root.
/_*.png
/_*.py
/debug-*.log
.jcs2-bot-wait/
__pycache__/
*.pyc

# OS/editor files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/

# Local project memory store
.projectmem/
